# ── Vercel KV (auto-populated when you add a KV store in the Vercel dashboard) ─
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ── Google OAuth (from console.cloud.google.com) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth.js secret — generate with: openssl rand -base64 32 ──────────────────
AUTH_SECRET=

# ── Agent API key — must match api_key in server config.json ─────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
OMNISTATE_API_KEY=

# ── Access control — only this Google account can sign in ────────────────────
ALLOWED_EMAIL=you@gmail.com
